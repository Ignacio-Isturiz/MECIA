# Archivo de ejemplo de variables de entorno
# Copia este archivo a .env y configura los valores reales

# Clave secreta para JWT (cambiar en producción)
SECRET_KEY=tu-clave-secreta-super-segura-en-produccion-cambiar-esto

# API Key para NewsAPI
NEWS_API_KEY=tu-api-key-de-newsapi
NEWS_API_BASE_URL=https://newsapi.org/v2

# Configuración SMTP para emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# Email remitente
FROM_EMAIL=noreply@mecia.com

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000